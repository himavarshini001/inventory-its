{
  "name": "inventory-its-server",
  "version": "1.0.0",
  "description": "Office Inventory Tracking System — Express API",
  "main": "src/app.js",
  "scripts": {
    "start":     "node src/app.js",
    "dev":       "nodemon src/app.js",
    "migrate":   "knex migrate:latest",
    "rollback":  "knex migrate:rollback",
    "seed":      "knex seed:run",
    "db:reset":  "knex migrate:rollback --all && knex migrate:latest && knex seed:run"
  },
  "dependencies": {
    "bcryptjs":           "^2.4.3",
    "cookie-parser":      "^1.4.6",
    "cors":               "^2.8.5",
    "dotenv":             "^16.4.5",
    "express":            "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "fast-csv":           "^5.0.1",
    "helmet":             "^7.1.0",
    "jsonwebtoken":       "^9.0.2",
    "knex":               "^3.1.0",
    "morgan":             "^1.10.0",
    "multer":             "^1.4.5-lts.1",
    "node-cron":          "^3.0.3",
    "nodemailer":         "^6.9.14",
    "pdfkit":             "^0.15.0",
    "pg":                 "^8.12.0",
    "redis":              "^4.6.14",
    "socket.io":          "^4.7.5",
    "zod":                "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
